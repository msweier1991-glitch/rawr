<dyad-write path="src/api/agents/linkedin.ts" description="LinkedIn agent implementation">
import { supabaseAdmin } from '@/utils/supabase-admin';
import { callClaude } from '@/utils/llm-server';

export async function runLinkedInAgent(runId: string) {
  try {
    // Get company context
    const { data: context } = await supabaseAdmin
      .from('company_context')
      .select('*')
      .eq('company_id', 'test-company')
      .single();

    // Build prompt
    const prompt = `You are a LinkedIn content strategist. Create a professional LinkedIn post about ${context?.name || 'rawr_'} (${context?.description || 'AI CMO platform'}).

Include:
- Hook that resonates with professionals
- 3 key insights or benefits
- Professional tone
- Relevant hashtags (max 5)
- Call-to-action

Format as a single post (not a carousel). Keep it under 1300 characters.`;

    // Call LLM
    const llmResponse = await callClaude({ prompt, model: 'claude-3-sonnet-20240229' });
    
    // Save to database
    const { data, error } = await supabaseAdmin
      .from('agent_outputs')
      .insert([{
        run_id: runId,
        agent_name: 'linkedin',
        content: {
          post: llmResponse.post || llmResponse.text || 'Generated content',
          hashtags: llmResponse.hashtags || []
        },
        status: 'pending_approval'
      }]);

    if (error) throw error;

    // Log event
    await supabaseAdmin
      .from('pipeline_events')
      .insert([{
        run_id: runId,
        message: 'LinkedIn Agent drafted post'
      }]);

  } catch (error) {
    console.error('LinkedIn agent error:', error);
    await supabaseAdmin
      .from('pipeline_events')
      .insert([{
        run_id: runId,
        message: `LinkedIn Agent failed: ${error.message}`
      }]);
  }
}